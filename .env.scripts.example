# ─────────────────────────────────────────────────────────────
# Used ONLY by scripts/create-admin-accounts.mjs — never imported by the
# app itself, never bundled into the browser build.
#
# Copy this file to .env.scripts and fill in your values.
# NEVER commit .env.scripts to version control (it's already in .gitignore).
# ─────────────────────────────────────────────────────────────

# Same project URL as VITE_SUPABASE_URL in your other env file.
SUPABASE_URL=https://your-project-ref.supabase.co

# From Supabase Project → Settings → API → Project API keys → "service_role"
# secret key. This key bypasses Row Level Security entirely — treat it like
# a database superuser password. Do not put it in any VITE_* variable, do
# not put it in .env.local, do not commit it anywhere.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
