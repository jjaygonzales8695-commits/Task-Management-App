# ─────────────────────────────────────────────────────────────
# Google OAuth & Sheets Configuration
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# ─────────────────────────────────────────────────────────────

# From Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client ID
VITE_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# The ID of your Google Spreadsheet (from the URL)
# https://docs.google.com/spreadsheets/d/SPREADSHEET_ID/edit
VITE_GOOGLE_SPREADSHEET_ID=your-spreadsheet-id-here

# (Optional) Google Drive folder ID where task evidence images will be uploaded
# Leave blank to upload to the root of My Drive
VITE_GOOGLE_DRIVE_FOLDER_ID=
