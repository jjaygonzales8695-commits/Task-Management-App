# ─────────────────────────────────────────────────────────────
# Supabase Configuration
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# ─────────────────────────────────────────────────────────────

# From Supabase Project -> Settings -> API -> Project URL
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# From Supabase Project -> Settings -> API -> Project API keys
# Use the "anon public" key (or "Publishable key" on newer projects)
VITE_SUPABASE_ANON_KEY=your-anon-or-publishable-key-here
